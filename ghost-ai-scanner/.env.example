# =============================================================
# FILE: .env.example
# PROJECT: PatronAI — Marauder Scan
# VERSION: 3.0.0
# UPDATED: 2026-06-11
# OWNER: Giggso Inc (Ravi Venugopal)
# PURPOSE: Annotated environment template for OCI deployment.
#          Copy to .env and fill in the REQUIRED section.
#          Or generate automatically via prereqs_oci.sh.
# USAGE:   cp .env.example .env
# AUDIT LOG:
#   v1.0.0  2026-04-29  Initial (AWS).
#   v2.0.0  2026-06-11  OCI migration — replaced AWS S3/SNS/SES
#                       with OCI Object Storage / ONS / Email Delivery.
#                       Added S3_ENDPOINT_URL (required for OCI).
#   v3.0.0  2026-06-11  Updated region to us-chicago-1.
#                       Added boto3 variable name comments.
#                       Updated CLOUD_PROVIDER to oci.
#                       Updated ALERT_SNS_ARN comment to OCI ONS.
#                       Updated GRAFANA_URL to OCI domain.
# =============================================================

# ── REQUIRED — change these before first start ───────────────

# OCI Object Storage bucket name (must already exist).
# Create via prereqs_oci.sh or OCI Console → Object Storage.
PATRONAI_BUCKET=

# OCI Object Storage S3-compatible endpoint.
# Format: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# Found in OCI Console → Object Storage → Bucket → S3 Compatibility
S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.us-chicago-1.oraclecloud.com

# Your organisation name — shown in the dashboard header and PDF reports.
COMPANY_NAME=Acme Corp

# URL-safe slug (lowercase, no spaces) — used in OCI Object Storage path prefixes.
COMPANY_SLUG=acme

# Admin email addresses. These users see every view including Support + Admin.
# Comma-separated, no spaces. Must also appear in ALLOWED_EMAILS.
ADMIN_EMAILS=admin@yourcompany.com

# All users allowed to log in. PatronAI uses email-only auth.
# Comma-separated, no spaces.
ALLOWED_EMAILS=admin@yourcompany.com,analyst@yourcompany.com


# ── OCI CREDENTIALS (S3-compatible) ──────────────────────────
# These variable names are required by boto3 (Python S3 SDK).
# boto3 reads AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION
# automatically from the environment — we reuse these names but store
# OCI Customer Secret Key values in them.
#
# How to generate Customer Secret Keys:
#   OCI Console → Profile (top-right) → My Profile → Customer Secret Keys → Generate
#
# NOTE: AWS_REGION here means OCI region — boto3 variable name only.
AWS_ACCESS_KEY_ID=         # OCI Customer Secret Key ID
AWS_SECRET_ACCESS_KEY=     # OCI Customer Secret Key
AWS_REGION=us-chicago-1    # OCI region (boto3 variable name — not AWS)


# ── ALERTS (optional) ────────────────────────────────────────
# OCI Notifications (ONS) topic OCID for email/SMS alerts.
# Created automatically by prereqs_oci.sh.
# Leave blank to use webhook-only alerts.
# NOTE: Variable named ALERT_SNS_ARN for code compatibility — stores OCI ONS topic OCID.
ALERT_SNS_ARN=

# Slack or Teams incoming webhook URL for HIGH/CRITICAL alert messages.
TRINITY_WEBHOOK_URL=
LOGANALYZER_WEBHOOK_URL=

# Additional alert recipient emails.
ALERT_RECIPIENTS=

# From-address for alert emails (must be verified in OCI Email Delivery).
PATRONAI_FROM_EMAIL=noreply@patronai.ai


# ── DASHBOARD CONFIGURATION (optional) ──────────────────────
# OCI VM public IP or DNS without protocol.
PUBLIC_HOST=

# Full Grafana base URL — takes precedence over PUBLIC_HOST.
GRAFANA_URL=https://patronai.giggso.com/grafana

# Support-tier users — see Manager + Support views but not Admin.
SUPPORT_EMAILS=

# CrowdStrike Falcon integration (enterprise only).
CROWDSTRIKE_ENABLED=false

# Cloud provider backend for network metadata resolution.
# NOTE: Set to oci — developer is updating network resolver code for OCI.
CLOUD_PROVIDER=oci


# ── GRAFANA ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-before-demo
GF_SECURITY_ADMIN_USER=admin


# ── LLM CHAT (auto-configured — override only if needed) ─────
LLM_PROVIDER=openai_compat
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=
LLM_API_KEY=
LLM_MODEL_REPO=LiquidAI/LFM2.5-1.2B-Thinking-GGUF
LLM_MODEL_FILE=
LLM_READ_TIMEOUT_S=180
LLM_MAX_TOKENS=384
LLM_PARALLEL_SLOTS=1
LLM_CTX_SIZE=16384


# ── SCAN TUNING (optional) ───────────────────────────────────
SCAN_INTERVAL_SECS=300
DEDUP_WINDOW_MINUTES=60
LOOKBACK_MINUTES=60
STRICT_MIN_RULES=50
INCLUDE_CLASSIFIER=0
